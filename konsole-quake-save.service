[Unit]
Description=Save Konsole-Quake session state before shutdown
DefaultDependencies=no
Before=shutdown.target reboot.target halt.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c 'if [ -f /tmp/konsole-quake.pid ] && kill -0 "$(cat /tmp/konsole-quake.pid)" 2>/dev/null; then python3 @SCRIPT_DIR@/konsole-quake-session.py save; fi'
TimeoutStartSec=10

[Install]
WantedBy=default.target
